+    def _forward_decode_triton(
+        self,
+        q: torch.Tensor,
+        kv_c_and_k_pe_cache: torch.Tensor,
+        attn_metadata: AttentionMetaData,
+    ) -> torch.Tensor:
+        """Triton MLA decode path for sub-16 head counts (e.g. TP8 with 8 heads).
+
+        Uses the Triton MLA kernel which handles arbitrary head counts natively,
+        avoiding head padding, q.repeat (float8_copy), and wasted compute on
+        duplicate heads. Q must be bf16 (not fp8) for this path.
+        """
+        B = q.shape[0]
+        num_kv_splits = 16
+
+        # q is bf16 (B, num_heads, kv_lora_rank + qk_rope_head_dim)
+        # KV cache: (total_tokens, kv_lora_rank + qk_rope_head_dim) — page_size=1
+        # Reshape to (total_tokens, 1, dim) for the Triton kernel (1 KV head)
+        dim = self.kv_lora_rank + self.qk_rope_head_dim
+        k_buffer = kv_c_and_k_pe_cache.view(-1, 1, dim)
+        # V is just the kv_lora_rank portion — same storage, narrowed view.
+        # Not contiguous (stride[0]=576 != 512) but the Triton kernel only
+        # accesses offs_c < kv_lora_rank via stride_buf_vbs, so this is fine.
+        v_buffer = kv_c_and_k_pe_cache.view(-1, 1, dim)[:, :, : self.kv_lora_rank]
+
+        paged_kv_indptr = attn_metadata.kv_indptr
+        paged_kv_indices = attn_metadata.kv_indices
