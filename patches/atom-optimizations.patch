+            q,
+            k_buffer,
+            v_buffer,
+            o,
+            paged_kv_indptr,
+            paged_kv_indices,
+            k_pe_tokens,
+            kv_lora_rank=self.kv_lora_rank,
+            rotary_dim=0,
+            cos_sin_cache=None,
+            positions=None,
+            attn_logits=attn_logits,
+            num_kv_splits=num_kv_splits,
+            sm_scale=self.scale,
+            logit_cap=0.0,
+            use_rope=False,
+            is_neox_style=False,
+        )
+
+        # Output is (B, num_heads, kv_lora_rank) — standard layout, no permute needed
+        return self._v_up_proj_and_o_proj(o)
