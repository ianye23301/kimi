             B = q.shape[0]
             if B <= 32:
                 return self._forward_decode_triton(q, kv_c_and_k_pe_cache, attn_metadata)
-            # Fallback to ASM for large batch — need fp8 Q for ASM kernel
-            if q.dtype != dtypes.fp8:
-                q = q.to(dtypes.fp8)
+            # Fallback to ASM — q is already fp8 (dtype decided at allocation)
 
         B = q.shape[0]
 
@@ -796,11 +794,15 @@ class MLAAttention(nn.Module):
             # Triton MLA decode needs bf16 Q (no fp8 support in Triton attention).
             # ASM path uses fp8 Q (dtype_q = dtype_kv). The fused_qk_rope kernel
             # supports both output dtypes — it checks q_out.scalar_type().
-            decode_q_dtype = (
-                self.dtype
-                if (self.use_triton_mla_decode and not context.is_prefill)
-                else attn_metadata.dtype_q
