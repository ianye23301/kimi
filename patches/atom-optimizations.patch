+            paged_kv_indices = triton_convert_req_index_to_global_index(
+                attn_metadata.cu_seqlens_q,
+                attn_metadata.kv_indptr,
+                paged_kv_indptr,
+                attn_metadata.kv_indices,
+                self.topk_indices_buffer[:B],
+                NUM_TOPK_TOKENS=self.topk_indices_buffer.shape[1],
+            )
+
+        # Output: (B, num_heads, kv_lora_rank) — native head count, no padding
+        o = torch.empty(
+            B, self.num_heads, self.kv_lora_rank,
+            dtype=q.dtype, device=q.device,
+        )
+
+        # Intermediate attention logits buffer
+        # Shape: (B, num_heads, num_kv_splits, kv_lora_rank + 1)
+        attn_logits = torch.empty(
+            B, self.num_heads, num_kv_splits, self.kv_lora_rank + 1,
+            dtype=torch.float32, device=q.device,
+        )
+
+        # k_pe_tokens not needed (RoPE already applied in KV cache)
+        k_pe_tokens = torch.empty(0, device=q.device)
+
